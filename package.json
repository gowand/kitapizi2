    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "connect-pg-simple": "^9.0.1",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}